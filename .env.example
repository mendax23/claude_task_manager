DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (required for Celery + Channels)
REDIS_URL=redis://localhost:6379/0

# Database (defaults to SQLite, uncomment for PostgreSQL)
# DATABASE_URL=postgres://user:pass@localhost:5432/agentqueue

# Optional: Default LLM API keys (can also be set per-provider in the UI)
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
